# Synoptic Data (MesoWest)
# Sign up at https://synopticdata.com/mesonet-api/
# Free tier: 500 requests/day, real-time data from 40,000+ stations
#
# IMPORTANT: This must be your TOKEN, not your API key.
# To get your token, visit:
#   https://api.synopticdata.com/v2/auth?apikey=YOUR_API_KEY
# Copy the TOKEN value from the response and paste it below.
SYNOPTIC_TOKEN=your_token_here
